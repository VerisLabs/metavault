[submodule "dependencies/forge-std"]
	path = dependencies/forge-std
	url = https://github.com/foundry-rs/forge-std
[submodule "dependencies/solidity-bytes-utils"]
	path = dependencies/solidity-bytes-utils
	url = https://github.com/GNSPS/solidity-bytes-utils
[submodule "dependencies/openzeppelin-contracts"]
	path = dependencies/openzeppelin-contracts
	url = https://github.com/OpenZeppelin/openzeppelin-contracts
[submodule "dependencies/solady"]
	path = dependencies/solady
	url = https://github.com/vectorized/solady
[submodule "dependencies/layerzero-v2"]
	path = dependencies/layerzero-v2
	url = https://github.com/LayerZero-Labs/layerzero-v2
[submodule "dependencies/devtools"]
	path = dependencies/devtools
	url = https://github.com/LayerZero-Labs/devtools
