pragma solidity ^0.8.19;

import "forge-std/Script.sol";

contract DeployScript is Script {
    function run() external {
        address CREATE2_DEPLOYER = 0x4e59b44847b379578588920cA78FbF26c0B4956C;
        address GATEWAY = 0x3228F64baE214d2562FaE387b5456BE10385648A;
        address SUPERPOSITIONS = 0x01dF6fb6a28a89d6bFa53b2b3F20644AbF417678;

        //bytecode+constructor args from the dry run output
        bytes memory bytecode =
            hex"";

        bytes32 salt = keccak256(abi.encode(8453, GATEWAY, SUPERPOSITIONS));

        vm.broadcast();
        (bool success,) = CREATE2_DEPLOYER.call(abi.encodePacked(salt, bytecode));
        require(success, "deployment failed");
    }
}
